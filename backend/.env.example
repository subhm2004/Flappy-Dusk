# Copy to .env and fill in. Never commit the real thing.

PORT=8080
NODE_ENV=development

# Local: the docker-compose Postgres below.
# Production: your Neon connection string.
DATABASE_URL=postgres://flappy:flappy@localhost:5432/flappy

# Any long random string: `openssl rand -base64 48`
JWT_SECRET=change-me-to-at-least-32-characters-of-random

# Google Cloud console -> Credentials -> OAuth client ID -> "Web application".
# Authorised redirect URI must be exactly: <API_URL>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# This service's own public URL.
API_URL=http://localhost:8080

# Where the browser lands after signing in.
WEB_APP_URL=http://localhost:3000

# Custom scheme that hands the session back to the installed Android app.
APP_SCHEME=com.subhm2004.flappydusk
